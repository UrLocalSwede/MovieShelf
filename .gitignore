# ---- Dependencies ----
node_modules/

# ---- Build output ----
# electron-vite bundles (main/preload/renderer)
out/
# electron-builder installers + win-unpacked (large; never commit)
dist/

# ---- Fetched runtime binaries (run `npm run fetch:deps`) ----
# The bundled uosc config under resources/mpv_config/ IS committed (incl. our custom
# mpv.conf and script-opts/uosc.conf); only the large downloaded engines are ignored.
resources/mpv/
resources/ffprobe/
resources/.build/

# ---- Local / generated state ----
# config.json may contain API keys — never commit
config.json
*.log

# ---- Editor / tooling ----
.claude/
.vscode/
.idea/

# ---- OS ----
Thumbs.db
desktop.ini
.DS_Store
