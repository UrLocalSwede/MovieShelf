# ---- Build output ----
# Keep build/MovieShelf.spec, ignore PyInstaller work dirs and the final exe.
build/*/
dist/

# Vendored native libs (fetched via tools/fetch_libmpv.py, not committed)
vendor/

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.venv/
venv/
env/

# ---- Local / generated state ----
settings.txt          # legacy local settings (now stored in %APPDATA%\MovieShelf)
config.json           # may contain API keys — never commit
*.log
tools/

# ---- Editor / tooling ----
.claude/
.vscode/
.idea/

# ---- OS ----
Thumbs.db
desktop.ini
.DS_Store
